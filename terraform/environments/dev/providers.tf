/*
Providers tell terraform which provider to download,
version family to use, and that we want the AzureRM provider enabled.
*/

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 4.0"
    }
  }
}

provider "azurerm" {
  features {}
}